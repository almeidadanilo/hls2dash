# hls2dash environment variables
# Copy this file to .env and adjust as needed.

VERSION=1.1.9

# Port the service listens on.
PORT=3100

# Base URL of this service, used when rewriting segment/key URLs in the MPD.
# Leave empty if running behind a reverse proxy that handles the public base URL.
# Example: https://myapp.com
PROXY_BASE=http://localhost:3100

# Maximum number of playlist entries to keep in the in-memory cache.
CACHE_MAX_CAPACITY=500

# HTTP timeout (seconds) for upstream HLS fetch requests.
UPSTREAM_TIMEOUT_SECS=15

# Tracing log level: error | warn | info | debug | trace
LOG_LEVEL=info

# Set to true to transmux MPEG-TS segments to fMP4 on the fly via ffmpeg.
# Requires ffmpeg to be installed and available in PATH.
# Enables DASH.js compatibility for HLS-TS streams.
TRANSMUX_TS=true
